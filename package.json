{
  "name": "auth-backend",
  "version": "0.1.0",
  "type": "module",
  "description": "Node.js auth server for Sesori Mobile App",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "start:local": "sops exec-env env/app/local.env 'tsx src/index.ts'",
    "start:prod": "sops exec-env env/app/prod.env 'tsx src/index.ts'",
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "test": "node --import tsx --test --test-concurrency=1 tests/**/*.test.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "generate-keys": "bash ./scripts/generate-keys.sh",
    "env:init": "bash ./scripts/env-init.sh",
    "env:decrypt": "sh -c 'sops decrypt env/app/${ENV:-local}.env > .env && echo \"Decrypted env/app/${ENV:-local}.env → .env\"'",
    "env:edit": "sh -c 'sops edit env/app/${ENV:-local}.env'",
    "env:update-keys": "sh -c 'for f in env/app/*.env; do [ -f \"$f\" ] && sops updatekeys -y \"$f\"; done'"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "fastify": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.2.7",
    "mongodb": "^7.1.0",
    "music-metadata": "^11.12.3",
    "openai": "^6.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.15",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
